{
  "name": "whitemountains-pictures",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm run typecheck && npm run test && npm run build && npm run verify:dist && npm run deploy:dry-run",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "dev": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:dist": "node scripts/verify-dist.mjs",
    "wrangler:types": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "latest",
    "@types/node": "^26.1.1",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
