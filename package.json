{
  "name": "whitemountains-pictures",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.js",
    "validate": "node scripts/validate-data.js",
    "search-index": "node scripts/build-search-index.js",
    "prerender": "node scripts/prerender-site.js",
    "sitemaps": "node scripts/generate-sitemaps.js",
    "build": "npm run clean && npm run validate && npm run search-index && npm run prerender && npm run sitemaps",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.65.0"
  }
}

